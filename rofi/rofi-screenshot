#!/usr/bin/env bash
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$DIR/../branding/lib.sh"

# Open processed image in an editor, save to file, notify, and clean up.
# Args: <processed.png> <output.png>
edit() {
  local processed="$1" file="$2"
  swappy -f "$processed" -o "$file"
  [[ -f "$file" ]] && notify-send "Screenshot saved" "$file"
  rm -f "$processed"
}

[[ "${BASH_SOURCE[0]}" != "${0}" ]] && return

options="рџ–ј  Fullscreen [Branded]\nрџ”І  Select Region [Branded]\nрџЄџ  Window [Branded]\nрџ–ј  Fullscreen\nрџ”І  Select Region\nрџЄџ  Window\nрџЄџ  Window [Fancy]\nвќЊ  Cancel"
choice=$(echo -e "$options" | rofi -dmenu -p "Screenshot" -theme ~/.config/rofi/theme.rasi)
file=~/Pictures/Screenshots/screenshot_$(date +%Y%m%d_%H%M%S).png

case "$choice" in
  "рџ–ј  Fullscreen [Branded]")
    tmpfile=$(mktemp /tmp/screenshot_XXXXXX.png)
    processed=$(mktemp /tmp/screenshot_XXXXXX.png)
    grim "$tmpfile"
    round_corners "$tmpfile"
    add_gradient_bg "$tmpfile" "$processed"
    rm "$tmpfile"
    add_branding "$processed"
    edit "$processed" "$file"
    ;;
  "рџ”І  Select Region [Branded]")
    tmpfile=$(mktemp /tmp/screenshot_XXXXXX.png)
    processed=$(mktemp /tmp/screenshot_XXXXXX.png)
    grim -g "$(slurp)" "$tmpfile"
    round_corners "$tmpfile"
    add_gradient_bg "$tmpfile" "$processed"
    rm "$tmpfile"
    add_branding "$processed"
    edit "$processed" "$file"
    ;;
  "рџЄџ  Window [Branded]")
    tmpfile=$(mktemp /tmp/screenshot_XXXXXX.png)
    processed=$(mktemp /tmp/screenshot_XXXXXX.png)
    win=$(hyprctl activewindow -j | jq -r '"\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"')
    grim -g "$win" "$tmpfile"
    round_corners "$tmpfile"
    add_gradient_bg "$tmpfile" "$processed"
    rm "$tmpfile"
    add_branding "$processed"
    edit "$processed" "$file"
    ;;
  "рџ–ј  Fullscreen")
    tmpfile=$(mktemp /tmp/screenshot_XXXXXX.png)
    grim "$tmpfile"
    edit "$tmpfile" "$file"
    ;;
  "рџ”І  Select Region")
    tmpfile=$(mktemp /tmp/screenshot_XXXXXX.png)
    grim -g "$(slurp)" "$tmpfile"
    edit "$tmpfile" "$file"
    ;;
  "рџЄџ  Window")
    tmpfile=$(mktemp /tmp/screenshot_XXXXXX.png)
    win=$(hyprctl activewindow -j | jq -r '"\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"')
    grim -g "$win" "$tmpfile"
    round_corners "$tmpfile"
    edit "$tmpfile" "$file"
    ;;
  "рџЄџ  Window [Fancy]")
    tmpfile=$(mktemp /tmp/screenshot_XXXXXX.png)
    processed=$(mktemp /tmp/screenshot_XXXXXX.png)
    win=$(hyprctl activewindow -j | jq -r '"\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"')
    grim -g "$win" "$tmpfile"
    round_corners "$tmpfile"
    add_gradient_bg "$tmpfile" "$processed"
    rm "$tmpfile"
    edit "$processed" "$file"
    ;;
  *Cancel)
    exit 0
    ;;
esac
